page { background-color: #f5f7fa; }

.page { padding: 30rpx; box-sizing: border-box; height: 100vh; }

.role-badge-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; padding: 16rpx 24rpx; background: #fff; border-radius: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.role-badge { font-size: 26rpx; font-weight: 600; color: #1677ff; }
.role-switch { font-size: 24rpx; color: #ff4d4f; }

.tool-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.tool-header { font-size: 34rpx; font-weight: 700; color: #333; margin-bottom: 8rpx; }
.toggle-arrow { font-size: 22rpx; color: #bbb; margin-left: 8rpx; }

/* 收藏列表 */
.fav-list { margin-top: 8rpx; }
.fav-item {
  padding: 20rpx; margin-bottom: 12rpx; background: #fafafa;
  border-radius: 12rpx; border-left: 4rpx solid #fa8c16;
}
.fav-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 6rpx; }
.fav-preview { font-size: 24rpx; color: #999; line-height: 1.5; margin-bottom: 6rpx; }
.fav-time { font-size: 20rpx; color: #bbb; }
.empty-tip-sm { text-align: center; padding: 30rpx; font-size: 24rpx; color: #bbb; }

/* 骨架屏 */
.skeleton { background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 8rpx; }
.skeleton-line { height: 28rpx; margin-bottom: 12rpx; }
.skeleton-line:nth-child(2) { width: 80%; }
.skeleton-line:nth-child(3) { width: 60%; }
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

/* 错题本 */
.kp-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin: 16rpx 0; }
.kp-tag { padding: 8rpx 20rpx; background: #f0f5ff; color: #1677ff; font-size: 24rpx; border-radius: 24rpx; border: 2rpx solid transparent; }
.kp-tag-active { background: #1677ff; color: #fff; }
.error-list-preview { margin: 16rpx 0; max-height: 340rpx; overflow-y: auto; }
.error-item { display: flex; align-items: flex-start; padding: 12rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.error-index { flex-shrink: 0; width: 48rpx; font-size: 22rpx; color: #1677ff; font-weight: 600; }
.error-text { flex: 1; font-size: 24rpx; color: #555; line-height: 1.5; word-break: break-all; }

.tool-desc { font-size: 24rpx; color: #999; margin-bottom: 20rpx; }

.tool-btn {
  width: 100%; height: 76rpx; line-height: 76rpx;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  color: #fff; font-size: 28rpx; font-weight: 600;
  border-radius: 38rpx; border: none; margin-top: 16rpx;
}

.tool-btn[disabled] { opacity: 0.5; }

.tool-result {
  margin-top: 20rpx; padding: 24rpx;
  background: #fafafa; border-radius: 12rpx; border: 1rpx solid #f0f0f0;
}

.tool-form { margin-top: 12rpx; }

.tool-input {
  margin-top: 10rpx; padding: 16rpx 20rpx;
  background: #f5f7fa; border-radius: 12rpx; font-size: 26rpx; color: #333;
}

.tool-textarea {
  width: 100%; min-height: 160rpx; padding: 16rpx; margin-top: 10rpx;
  background: #f5f7fa; border-radius: 12rpx; font-size: 26rpx; color: #333;
  line-height: 1.6; box-sizing: border-box;
}

.param-label { font-size: 26rpx; color: #888; display: block; }
.param-row { display: flex; gap: 24rpx; }
.param-col { flex: 1; }
.picker-box {
  margin-top: 10rpx; padding: 16rpx 20rpx; background: #f5f7fa;
  border-radius: 12rpx; font-size: 26rpx; color: #333; text-align: center;
}

.pref-status { display: block; margin-top: 12rpx; font-size: 24rpx; color: #52c41a; }

/* 数据看板卡片 */
.dash-cards { margin-bottom: 20rpx; }
.dash-row { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.dash-card {
  flex: 1; border-radius: 16rpx; padding: 24rpx 16rpx; text-align: center;
  background: linear-gradient(135deg, #f0f5ff, #e6f7ff);
}
.dash-card:nth-child(2) { background: linear-gradient(135deg, #fff7e6, #fffbe6); }
.dash-card:nth-child(3) { background: linear-gradient(135deg, #f6ffed, #e6ffe6); }
.dash-num { display: block; font-size: 44rpx; font-weight: 700; color: #1677ff; margin-bottom: 6rpx; }
.dash-card:nth-child(2) .dash-num { color: #fa8c16; }
.dash-card:nth-child(3) .dash-num { color: #52c41a; }
.dash-label { display: block; font-size: 22rpx; color: #888; }

.dash-progress-section { background: #fafafa; border-radius: 12rpx; padding: 20rpx 24rpx; margin-bottom: 20rpx; }
.dash-progress-header { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.dash-progress-label { font-size: 26rpx; color: #555; }
.dash-progress-pct { font-size: 26rpx; color: #1677ff; font-weight: 600; }
.dash-donut-row { display: flex; align-items: center; gap: 20rpx; }
.dash-donut { width: 100rpx; height: 100rpx; border-radius: 50%; flex-shrink: 0; }
.dash-donut-inner { width: 68rpx; height: 68rpx; border-radius: 50%; background: #fff; margin: 16rpx; display: flex; align-items: center; justify-content: center; }
.donut-num { font-size: 24rpx; font-weight: 700; color: #1677ff; }
.dash-progress-bar { height: 14rpx; background: #e8e8e8; border-radius: 7rpx; overflow: hidden; }
.dash-progress-fill { height: 100%; background: linear-gradient(90deg, #1677ff, #52c41a); border-radius: 7rpx; transition: width 0.6s ease; }

/* 柱状图 */
.dash-chart { margin-top: 20rpx; }
.dash-chart-title { font-size: 26rpx; font-weight: 600; color: #555; display: block; margin-bottom: 16rpx; }
.bar-item { display: flex; align-items: center; margin-bottom: 12rpx; gap: 12rpx; }
.bar-label { width: 100rpx; font-size: 22rpx; color: #888; text-align: right; flex-shrink: 0; }
.bar-track { flex: 1; height: 20rpx; background: #f0f0f0; border-radius: 10rpx; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 10rpx; transition: width 0.8s ease; }
.bar-color-0 { background: linear-gradient(90deg, #1677ff, #69c0ff); }
.bar-color-1 { background: linear-gradient(90deg, #52c41a, #95de64); }
.bar-color-2 { background: linear-gradient(90deg, #fa8c16, #ffc069); }
.bar-color-3 { background: linear-gradient(90deg, #722ed1, #b37feb); }
.bar-color-4 { background: linear-gradient(90deg, #eb2f96, #ff85c0); }
.bar-pct { width: 60rpx; font-size: 22rpx; color: #555; font-weight: 600; flex-shrink: 0; }
