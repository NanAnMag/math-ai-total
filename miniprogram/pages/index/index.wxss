page { background-color: #f5f7fa; }

.page { padding: 40rpx 30rpx; min-height: 100vh; box-sizing: border-box; }

.header { text-align: center; padding: 40rpx 0 20rpx; }
.header-icon { font-size: 96rpx; margin-bottom: 20rpx; }
.header-title { font-size: 44rpx; font-weight: 700; color: #1677ff; margin-bottom: 16rpx; }
.header-subtitle { font-size: 26rpx; color: #999; line-height: 1.5; }
.header-user { margin-top: 12rpx; display: flex; justify-content: center; align-items: center; gap: 20rpx; }
.user-name { font-size: 24rpx; color: #1677ff; }
.user-logout { font-size: 22rpx; color: #ff4d4f; }

/* 今日概况 */
.overview-card {
  background: linear-gradient(135deg, #1677ff, #4096ff);
  border-radius: 20rpx; padding: 24rpx 12rpx; margin-bottom: 24rpx;
}
.overview-row { display: flex; align-items: center; }
.overview-item { flex: 1; text-align: center; }
.overview-num { display: block; font-size: 40rpx; font-weight: 700; color: #fff; margin-bottom: 4rpx; }
.overview-blue { color: #bae7ff; }
.overview-green { color: #b7eb8f; }
.overview-label { font-size: 22rpx; color: rgba(255,255,255,0.7); }
.overview-divider { width: 2rpx; height: 48rpx; background: rgba(255,255,255,0.2); flex-shrink: 0; }

.card-list { display: flex; flex-direction: column; gap: 24rpx; margin-top: 0; }

.card {
  display: flex; align-items: center;
  background-color: #fff; border-radius: 20rpx; padding: 32rpx 28rpx;
  border: 2rpx solid #f0f0f0;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); transition: all 0.2s ease;
}
.card:active { transform: scale(0.98); border-color: #1677ff; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }

.card-icon {
  font-size: 64rpx; width: 100rpx; height: 100rpx; display: flex;
  align-items: center; justify-content: center;
  background-color: #f0f5ff; border-radius: 24rpx; margin-right: 24rpx; flex-shrink: 0;
}

.card-body { flex: 1; }
.card-title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 10rpx; }
.card-desc { font-size: 26rpx; color: #888; line-height: 1.6; }

.footer { text-align: center; padding: 48rpx 0 20rpx; font-size: 24rpx; color: #bbb; }
