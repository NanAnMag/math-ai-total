/**analysis.wxss**/
page {
  background-color: #f5f7fa;
}

.page {
  padding: 20rpx 30rpx;
  padding-bottom: 60rpx;
}

/* ========== Tab 切换 ========== */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #888;
  border-radius: 12rpx;
}

.tab-active {
  background: #1677ff;
  color: #fff;
  font-weight: 600;
}

/* ========== 智能体标识 ========== */
.agent-header {
  text-align: center;
  padding: 20rpx 0 30rpx;
}

.agent-badge {
  display: inline-block;
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 32rpx;
  margin-bottom: 12rpx;
}

.agent-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* ========== 区块标题 ========== */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  flex: 1;
}

.refresh-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background-color: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 32rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.refresh-btn:active {
  background-color: #f5f5f5;
}

.refresh-icon {
  font-size: 26rpx;
  margin-right: 4rpx;
}

.refresh-text {
  font-size: 24rpx;
  color: #666;
}

/* ========== 输入区域 ========== */
.input-section {
  margin-bottom: 32rpx;
}

.wrong-input {
  width: 100%;
  min-height: 280rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background-color: #fff;
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.placeholder {
  color: #bbb;
}

.input-footer {
  display: flex;
  justify-content: flex-end;
  padding: 10rpx 8rpx 0;
}

.char-count {
  font-size: 22rpx;
  color: #bbb;
}

.submit-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #1677ff;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn[disabled] {
  background-color: #a0c4ff;
  color: rgba(255, 255, 255, 0.7);
}

/* ========== 加载状态 ========== */
.loading-area {
  padding: 40rpx 0;
}

.loading-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid #e8f0fe;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #888;
}

/* ========== 分析结果 ========== */
.result-section {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.result-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.card-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.card-content {
  padding-left: 4rpx;
}

.text-block {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

/* 知识点标签 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  margin: 6rpx 10rpx 6rpx 0;
  background-color: #f0f5ff;
  color: #1677ff;
  font-size: 24rpx;
  border-radius: 32rpx;
}

/* 掌握水平进度条 */
.level-bar-bg {
  width: 100%;
  height: 16rpx;
  background-color: #e8f0fe;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.level-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #1677ff, #52c41a);
  border-radius: 8rpx;
  transition: width 0.6s ease;
}

.level-text {
  font-size: 26rpx;
  color: #888;
}

/* ========== 操作按钮 ========== */
.action-btn-msg { text-align: center; font-size: 24rpx; color: #52c41a; padding: 12rpx 0; }

.workflow-btn {
  background: linear-gradient(135deg, #722ed1, #eb2f96) !important;
  box-shadow: 0 6rpx 20rpx rgba(114,46,209,0.3) !important;
  margin-top: 16rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(22, 119, 255, 0.3);
}

.action-btn:active {
  opacity: 0.85;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #bbb;
  text-align: center;
}

/* ========== 作业批改 ========== */
.section-title-sm {
  font-size: 28rpx;
  font-weight: 600;
  color: #555;
  margin: 20rpx 0 12rpx;
}

.upload-section {
  margin-bottom: 20rpx;
}

.upload-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.upload-box {
  width: 180rpx;
  height: 180rpx;
  background: #fff;
  border: 2rpx dashed #d0d0d0;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 20rpx;
  color: #aaa;
  text-align: center;
}

.upload-preview {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.upload-tip {
  flex: 1;
}

.upload-tip text {
  font-size: 22rpx;
  color: #bbb;
  line-height: 1.5;
}

.grade-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #fff;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.grade-result-scroll {
  height: calc(100vh - 500rpx);
}

.content-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* ========== 智能错题本 ========== */
.error-list-preview {
  margin: 16rpx 0;
  max-height: 340rpx;
  overflow-y: auto;
}

.error-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.error-index {
  flex-shrink: 0;
  width: 48rpx;
  font-size: 22rpx;
  color: #1677ff;
  font-weight: 600;
}

.error-text {
  flex: 1;
  font-size: 24rpx;
  color: #555;
  line-height: 1.5;
  word-break: break-all;
}

.empty-tip-sm {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #bbb;
}

/* 筛选标签 */
.kp-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin: 16rpx 0; }
.kp-tag {
  padding: 8rpx 20rpx; background: #f0f5ff; color: #1677ff;
  font-size: 24rpx; border-radius: 24rpx; border: 2rpx solid transparent;
}
.kp-tag-active { background: #1677ff; color: #fff; }

