/**chat.wxss**/
page { background-color: #ededed; height: 100vh; }

.page { height: 100vh; display: flex; flex-direction: column; padding: 20rpx 24rpx 0; box-sizing: border-box; }

.chat-wrapper { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

/* Tab */
.tab-bar { display: flex; background: #fff; border-radius: 16rpx; padding: 8rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); flex-shrink: 0; }
.tab-item { flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; color: #888; border-radius: 12rpx; }
.tab-active { background: #1677ff; color: #fff; font-weight: 600; }

/* 快捷公式 */
.quick-formulas { margin-bottom: 16rpx; }
.quick-label { font-size: 24rpx; color: #999; margin-right: 8rpx; }
.quick-tags { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 8rpx; }
.quick-tag { padding: 8rpx 18rpx; font-size: 24rpx; background: #f0f5ff; color: #1677ff; border-radius: 24rpx; }
.quick-tag:active { background: #1677ff; color: #fff; }

/* 公式推导 */
.agent-header { text-align: center; padding: 10rpx 0 20rpx; }
.agent-badge { display: inline-block; padding: 10rpx 28rpx; background: linear-gradient(135deg, #52c41a, #1677ff); color: #fff; font-size: 28rpx; font-weight: 600; border-radius: 32rpx; margin-bottom: 8rpx; }
.agent-desc { display: block; font-size: 24rpx; color: #999; }
.input-section { margin-bottom: 20rpx; }
.formula-input { width: 100%; min-height: 160rpx; padding: 20rpx; border-radius: 12rpx; background: #fff; font-size: 26rpx; color: #333; line-height: 1.6; box-sizing: border-box; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03); }
.submit-btn { margin-top: 20rpx; width: 100%; height: 80rpx; line-height: 80rpx; background-color: #1677ff; color: #fff; font-size: 28rpx; font-weight: 600; border-radius: 40rpx; border: none; }
.submit-btn[disabled] { background-color: #a0c4ff; }
.loading-area { padding: 40rpx 0; text-align: center; }
.loading-card { display: flex; flex-direction: column; align-items: center; padding: 40rpx; background: #fff; border-radius: 16rpx; }
.loading-spinner { width: 48rpx; height: 48rpx; border: 5rpx solid #e8f0fe; border-top-color: #1677ff; border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 16rpx; }
@keyframes spin { to { transform: rotate(360deg); } }
.formula-result-scroll { height: calc(100vh - 380rpx); }
.content-box { background: #fff; border-radius: 16rpx; padding: 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 60rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 26rpx; color: #bbb; text-align: center; }

/* 聊天区域 */
.chat-area { flex: 1; padding: 20rpx 24rpx; box-sizing: border-box; overflow-y: auto; }

/* 空状态 */
.empty-chat { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.empty-chat .empty-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.empty-chat .empty-title { font-size: 34rpx; font-weight: 600; color: #555; margin-bottom: 12rpx; display: block; }
.empty-chat .empty-desc { font-size: 26rpx; color: #aaa; display: block; }

/* 消息 */
.msg-wrapper { margin-bottom: 28rpx; }
.msg-ai { display: flex; align-items: flex-start; }
.ai-avatar { width: 72rpx; height: 72rpx; font-size: 40rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-right: 12rpx; }
.ai-bubble { background-color: #ffffff; border-radius: 8rpx 20rpx 20rpx 20rpx; }
.msg-user { display: flex; align-items: flex-start; justify-content: flex-end; }
.user-avatar { width: 72rpx; height: 72rpx; font-size: 40rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-left: 12rpx; }
.user-bubble { background-color: #1677ff; border-radius: 20rpx 8rpx 20rpx 20rpx; }
.msg-bubble { max-width: 75%; padding: 20rpx 24rpx; position: relative; }
.msg-text { font-size: 28rpx; line-height: 1.7; color: #333; word-break: break-all; }
.user-bubble .msg-text { color: #ffffff; }

/* 输入中动画 */
.typing-bubble { padding: 24rpx 28rpx; }
.typing-dots { display: flex; align-items: center; gap: 10rpx; }
.dot { width: 14rpx; height: 14rpx; border-radius: 50%; background-color: #bbb; animation: blink 1.4s ease-in-out infinite; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes blink { 0%,60%,100% { opacity:0.2; transform:scale(0.8); } 30% { opacity:1; transform:scale(1); } }

/* 固定底部输入栏 */
.input-bar {
  display: flex; align-items: center; gap: 16rpx; flex-shrink: 0;
  padding: 14rpx 20rpx; padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  background-color: #f6f6f6; border-top: 1rpx solid #e0e0e0;
}
.msg-input { flex: 1; height: 76rpx; padding: 0 24rpx; background-color: #ffffff; border-radius: 38rpx; font-size: 28rpx; color: #333; }
.input-placeholder { color: #bbb; }
.send-btn { width: 120rpx; height: 76rpx; line-height: 76rpx; padding: 0; background-color: #1677ff; color: #fff; font-size: 28rpx; font-weight: 500; border-radius: 38rpx; border: none; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.send-btn[disabled] { background-color: #a0c4ff; color: rgba(255,255,255,0.6); }

/* 语音播报 */
.voice-controls { display: flex; align-items: center; gap: 16rpx; margin-top: 16rpx; padding: 16rpx 24rpx; background: #fff; border-radius: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.voice-play-btn { width: 200rpx; height: 64rpx; line-height: 64rpx; padding: 0; font-size: 26rpx; border-radius: 32rpx; border: none; background: #52c41a; color: #fff; font-weight: 600; }
.voice-status-text { font-size: 24rpx; color: #888; }

/* 词级高亮 */
.voice-word-box { font-size: 32rpx; line-height: 2.4; }
.voice-word { display: inline; color: #888; transition: color 0.15s, background 0.15s; }
.voice-word-active { color: #1677ff; font-weight: 700; background: #e6f7ff; border-radius: 4rpx; padding: 2rpx 4rpx; }
